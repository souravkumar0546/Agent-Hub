# Database
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/syngene_hub

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440

# CORS
CORS_ORIGINS=http://localhost:5173

# Azure OpenAI (used by agents later)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_MODEL=gpt-4o-mini

# Bootstrap super admin (seeded on first run)
BOOTSTRAP_SUPER_ADMIN_EMAIL=souravkumar@uniqus.com
BOOTSTRAP_SUPER_ADMIN_PASSWORD=change-me-on-first-login
BOOTSTRAP_SUPER_ADMIN_NAME=Sourav Kumar
